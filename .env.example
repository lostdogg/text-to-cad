# Runtime mode: 'local' or 'cloud'
MODE=local

# Server
HOST=0.0.0.0
PORT=8000

# Optional: enable GPT-4 NLP parsing
# OPENAI_API_KEY=sk-...

# CORS (comma-separated or JSON list)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Worker threads
MAX_WORKERS=4

# Export directory
EXPORT_DIR=exports
