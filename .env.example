# Runtime mode: 'local' or 'cloud'
MODE=local

# Server
HOST=0.0.0.0
PORT=8000

# ── AI Providers ────────────────────────────────────────────────────────────
# Users can also supply their own keys directly from the UI; these are
# optional server-side defaults only.

# OpenAI (GPT-4o, GPT-4, …)
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI / Gemini
# GOOGLE_API_KEY=AIza...

# Ollama (local models — change base URL if Ollama runs elsewhere)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Server ───────────────────────────────────────────────────────────────────

# CORS (comma-separated or JSON list)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Worker threads
MAX_WORKERS=4

# Export directory
EXPORT_DIR=exports
